# ── Provider API keys ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── LiteLLM ─────────────────────────────────────────────────────────────────
# Master key for LiteLLM admin API; also used as default embedding API key
LITELLM_MASTER_KEY=sk-litellm-change-me

# ── Internal service auth ────────────────────────────────────────────────────
# Shared secret between cache/observability and other services
INTERNAL_API_KEY=change-me-internal-key
# Auth token for admin service internal API calls
ADMIN_INTERNAL_TOKEN=
# WebSocket relay secret
AGENT_RELAY_SECRET=
# Scanner worker secret
SCANNER_WORKER_SECRET=change-me-scanner-secret
# Identity service token
IDENTITY_SERVICE_TOKEN=
# Librarian service token
LIBRARIAN_SERVICE_TOKEN=

# ── Embeddings ───────────────────────────────────────────────────────────────
# Routed through litellm by default (uses LITELLM_MASTER_KEY above)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=http://litellm:8003/v1
EMBEDDING_MODEL=text-embedding-3-small

# ── GHCR image tag (used by docker compose) ─────────────────────────────────
# Leave blank to use :latest; set to sha-<sha> for pinned deploys
IMAGE_TAG=
