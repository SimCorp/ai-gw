# Copy this file to .env and fill in values for local development.
# All provider keys are optional — only set the ones you intend to use.

# ── Shared infrastructure ─────────────────────────────────────────────────────
POSTGRES_DB=aigateway
POSTGRES_USER=aigateway
POSTGRES_PASSWORD=aigateway
DATABASE_URL=postgresql+asyncpg://aigateway:aigateway@postgres:5432/aigateway

REDIS_URL=redis://redis:6379/0

# ── Auth service (:8001) ───────────────────────────────────────────────────────
JWKS_URI=http://dex:5556/dex/keys
ENTRA_TENANT_ID=local
ENTRA_CLIENT_ID=ai-gateway-admin
RATE_LIMIT_DEFAULT_RPM=1000

# ── Cache service (:8002) ──────────────────────────────────────────────────────
LITELLM_URL=http://litellm:8003
SECONDARY_GATEWAY_URL=
SECONDARY_GATEWAY_SAMPLE_RATE=0.0
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=sk-local-placeholder
EMBEDDING_BASE_URL=http://ollama:11434/v1
DEFAULT_SIMILARITY_THRESHOLD=0.95
DEFAULT_TTL_SECONDS=3600

# ── LiteLLM proxy (:8003) ─────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-litellm-local-dev
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GITHUB_MODELS_API_KEY=
GITHUB_COPILOT_TOKEN=

# Azure OpenAI (via Azure AI Foundry — OpenAI model deployments)
# Azure portal → your Azure OpenAI resource → Keys and Endpoint
AZURE_API_BASE=
AZURE_API_KEY=
AZURE_API_VERSION=2025-01-01-preview

# Azure AI Foundry — Serverless inference (Phi, Llama, Mistral, DeepSeek, Cohere)
# Azure AI Foundry portal → your project → Overview → Azure AI Services endpoint
# One endpoint + key gives access to all serverless models in the project
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_KEY=

# ── Observability service (:8004) ─────────────────────────────────────────────
BUS_PROVIDER=memory
# Set for Azure production:
# AZURE_SERVICE_BUS_CONNECTION_STRING=
# APPINSIGHTS_CONNECTION_STRING=

# ── Admin portal (:8005) ──────────────────────────────────────────────────────
SECRET_KEY=local-dev-secret-change-in-production
DEV_BYPASS_AUTH=true
OIDC_ISSUER=http://dex:5556/dex
OIDC_CLIENT_ID=ai-gateway-admin
OIDC_CLIENT_SECRET=ai-gateway-admin-secret
PORTAL_BASE_URL=http://localhost:3001

# ── Email (weekly digest, password reset, etc.) ────────────────────────────────
# Leave SMTP_HOST empty to disable email sending (log-only mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=AI Gateway <noreply@simcorp.com>

# ── Workday sync (:8005 background job) ────────────────────────────────────────
WORKDAY_SYNC_ENABLED=false
WORKDAY_API_URL=
