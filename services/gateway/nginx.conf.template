# ai-gw front door — path-routes the gateway FQDN to portals and services.
# Rendered by entrypoint.sh (envsubst): ${DNS_RESOLVER} ${ENV_SUFFIX}
worker_processes auto;

events { worker_connections 1024; }

http {
  # Resolve upstreams at request time via the ACA environment DNS so a missing
  # app degrades to a 502 for its path instead of preventing nginx startup.
  resolver ${DNS_RESOLVER} valid=10s ipv6=off;

  map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
  }

  server {
    listen 8080;
    client_max_body_size 32m;

    proxy_http_version 1.1;
    # NOTE: Host header is left as the upstream host (nginx default) — ACA
    # ingress routes by Host. Original host is forwarded for the apps.
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_read_timeout 300s;
    proxy_buffering off;  # required for SSE streaming (cache/litellm)

    location = /healthz { return 200 'ok'; }
    location = / { return 302 /portal/portal; }

    # ── Portals (Next.js basePath = URL prefix, no rewrite) ──
    location /admin-portal {
      set $u http://ca-admin-portal-${ENV_SUFFIX};
      proxy_pass $u;
    }
    location /portal {
      set $u http://ca-portal-${ENV_SUFFIX};
      proxy_pass $u;
    }

    # ── Services (strip the path prefix) ──
    location /auth/ {
      set $u http://ca-auth-${ENV_SUFFIX};
      rewrite ^/auth/(.*)$ /$1 break;
      proxy_pass $u;
    }
    location /cache/ {
      set $u http://ca-cache-${ENV_SUFFIX};
      rewrite ^/cache/(.*)$ /$1 break;
      proxy_pass $u;
    }
    location /litellm/ {
      set $u http://ca-litellm-${ENV_SUFFIX};
      rewrite ^/litellm/(.*)$ /$1 break;
      proxy_pass $u;
    }
    location /admin/ {
      set $u http://ca-admin-${ENV_SUFFIX};
      rewrite ^/admin/(.*)$ /$1 break;
      proxy_pass $u;
    }
    location /identity/ {
      set $u http://ca-identity-${ENV_SUFFIX};
      rewrite ^/identity/(.*)$ /$1 break;
      proxy_pass $u;
    }
    location /librarian/ {
      set $u http://ca-librarian-${ENV_SUFFIX};
      rewrite ^/librarian/(.*)$ /$1 break;
      proxy_pass $u;
    }
    location /memory/ {
      set $u http://ca-memory-${ENV_SUFFIX};
      rewrite ^/memory/(.*)$ /$1 break;
      proxy_pass $u;
    }
    location /league/ {
      set $u http://ca-league-${ENV_SUFFIX};
      rewrite ^/league/(.*)$ /$1 break;
      proxy_pass $u;
    }
    location /observability/ {
      set $u http://ca-observability-${ENV_SUFFIX};
      rewrite ^/observability/(.*)$ /$1 break;
      proxy_pass $u;
    }
    location /agent-relay/ {
      set $u http://ca-agent-relay-${ENV_SUFFIX};
      rewrite ^/agent-relay/(.*)$ /$1 break;
      proxy_pass $u;
    }
  }
}
