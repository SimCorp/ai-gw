{
	admin off
	auto_https off
}

# Plain HTTP -> redirect to HTTPS (port 80 is open for this + future config needs).
:80 {
	redir https://{host}{uri} permanent
}

:443 {
	encode gzip
	tls /etc/caddy/cert.pem /etc/caddy/key.pem

	# Keep service /metrics internal: only /api/<svc>/* (handle_path strips the prefix)
	# could reach a service-root /metrics. This matcher is more specific than
	# /api/<svc>/* so Caddy evaluates it first (verified via `caddy adapt`). Alloy
	# scrapes /metrics over the internal aigateway network, never through Caddy.
	@apimetrics path /api/*/metrics
	handle @apimetrics {
		respond 404
	}

	# Inference — frozen external contracts (OpenAI + Anthropic SDKs).
	handle /v1/* {
		reverse_proxy cache:8002
	}
	handle /anthropic/* {
		reverse_proxy cache:8002
	}

	# Admin portal (Next.js basePath /admin — keep the prefix).
	handle /admin* {
		reverse_proxy admin-portal:3001
	}

	# Backend service APIs — strip /api/<svc>/ -> service root.
	handle_path /api/admin/* {
		reverse_proxy admin:8005
	}
	handle_path /api/cache/* {
		reverse_proxy cache:8002
	}
	handle_path /api/litellm/* {
		reverse_proxy litellm:8003
	}
	handle_path /api/identity/* {
		reverse_proxy identity:8006
	}
	handle_path /api/librarian/* {
		reverse_proxy librarian:8008
	}
	handle_path /api/memory/* {
		reverse_proxy memory:8009
	}
	handle_path /api/league/* {
		reverse_proxy league:8010
	}
	handle_path /api/observability/* {
		reverse_proxy observability:8004
	}

	# WebSocket relay bus (internal; prefix kept).
	handle /agent-relay/* {
		reverse_proxy agent-relay:8007
	}

	# OIDC / login — frozen (keeps the OIDC redirect URI /auth/oidc/callback stable).
	handle /auth/* {
		reverse_proxy admin:8005
	}

	# Gateway health. /healthz kept as an alias for existing probes.
	handle /health {
		respond "ok" 200
	}
	handle /healthz {
		respond "ok" 200
	}

	# Observability — Grafana UI (sub-path; obs-grafana sets GF_SERVER_ROOT_URL +
	# serve_from_sub_path). Behind Grafana's own login + the corp ZPA boundary.
	handle /grafana/* {
		reverse_proxy obs-grafana:3000
	}

	# Raw LogQL/PromQL query APIs for off-VM agents, behind basic_auth (creds in
	# pass; bcrypt hash via OBS_QUERY_BCRYPT). /obs/loki/api/... -> Loki (strip /obs,
	# Loki namespaces under /loki); /obs/prom/api/... -> Prometheus (strip /obs/prom).
	handle /obs/loki/* {
		basic_auth {
			obs {$OBS_QUERY_BCRYPT}
		}
		uri strip_prefix /obs
		reverse_proxy obs-loki:3100
	}
	handle_path /obs/prom/* {
		basic_auth {
			obs {$OBS_QUERY_BCRYPT}
		}
		reverse_proxy obs-prometheus:9090
	}

	# Dev portal at the root — catch-all for everything not matched above
	# (Next.js app with no basePath: /, /keys, /docs, /_next/*, assets, …).
	handle {
		reverse_proxy portal:3002
	}
}
