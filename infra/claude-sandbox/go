#!/usr/bin/env bash
# go — start Claude Code through the SimCorp AI Gateway
# Usage: go [optional prompt]

set -euo pipefail

GATEWAY="${GATEWAY_URL:-http://cache:8002}"
ADMIN="${GATEWAY_ADMIN_URL:-http://admin:8005}"
ADMIN_TOKEN="${ADMIN_TOKEN:-local-dev-admin-key-change-in-prod}"

# ── colours ──────────────────────────────────────────────────────────────────
B='\033[1m'; G='\033[32m'; Y='\033[33m'; C='\033[36m'; R='\033[31m'; X='\033[0m'

banner() {
    echo -e "${C}"
    echo "  ╔══════════════════════════════════════════╗"
    echo "  ║   SimCorp AI Gateway — Claude Sandbox   ║"
    echo "  ╚══════════════════════════════════════════╝"
    echo -e "${X}"
}

ok()   { echo -e "  ${G}✓${X} $*"; }
warn() { echo -e "  ${Y}!${X} $*"; }
err()  { echo -e "  ${R}✗${X} $*"; }
ask()  { echo -e "  ${B}?${X} $*"; }

# ── 1. Banner ─────────────────────────────────────────────────────────────────
clear
banner

# ── 2. Gateway health check ───────────────────────────────────────────────────
echo -e "${B}Checking gateway...${X}"
HTTP=$(curl -fsS -o /dev/null -w "%{http_code}" --max-time 5 "${GATEWAY}/health" 2>/dev/null || echo "000")
if [[ "$HTTP" == "200" ]]; then
    ok "Gateway reachable at ${GATEWAY}"
else
    err "Gateway not responding (HTTP ${HTTP})"
    warn "Make sure the stack is running: docker compose up --wait"
    echo ""
    read -rp "  Continue anyway? [y/N] " yn
    [[ "$yn" =~ ^[Yy]$ ]] || exit 1
fi
echo ""

# ── 3. API key setup ──────────────────────────────────────────────────────────
if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    ok "ANTHROPIC_API_KEY already set (${ANTHROPIC_API_KEY:0:8}...)"
    echo ""
    read -rp "  Use this key? [Y/n] " yn
    if [[ "$yn" =~ ^[Nn]$ ]]; then
        unset ANTHROPIC_API_KEY
    fi
fi

if [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
    echo -e "${B}API Key Setup${X}"
    echo ""
    echo "  You need a gateway sk- key. Options:"
    echo "    1) Enter a key you already have"
    echo "    2) Create a new key right now"
    echo "    3) Open the self-service portal (browser)"
    echo ""
    ask "Choose [1/2/3]:"
    read -rp "  > " choice

    case "$choice" in
        1)
            echo ""
            ask "Paste your gateway key (sk-...):"
            read -rsp "  > " key; echo ""
            export ANTHROPIC_API_KEY="$key"
            ;;
        2)
            echo ""
            # List existing teams or create one
            TEAMS=$(curl -fsS --max-time 5 \
                -H "X-Admin-Token: ${ADMIN_TOKEN}" \
                "${ADMIN}/teams" 2>/dev/null | python3 -m json.tool 2>/dev/null || echo "[]")

            TEAM_COUNT=$(echo "$TEAMS" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d))" 2>/dev/null || echo "0")

            if [[ "$TEAM_COUNT" -gt "0" ]]; then
                echo ""
                echo "  Existing teams:"
                echo "$TEAMS" | python3 -c "
import sys, json
teams = json.load(sys.stdin)
for i, t in enumerate(teams, 1):
    print(f'    {i}) {t[\"name\"]} ({t[\"id\"][:8]}...)')
"
                echo "    n) Create new team"
                echo ""
                ask "Pick a team [1-${TEAM_COUNT}/n]:"
                read -rp "  > " tchoice

                if [[ "$tchoice" == "n" ]]; then
                    TEAM_ID=""
                else
                    TEAM_ID=$(echo "$TEAMS" | python3 -c "
import sys, json
teams = json.load(sys.stdin)
idx = int('$tchoice') - 1
print(teams[idx]['id'])
" 2>/dev/null || echo "")
                fi
            fi

            if [[ -z "${TEAM_ID:-}" ]]; then
                echo ""
                ask "New team name (e.g. 'my-sandbox'):"
                read -rp "  > " tname
                slug=$(echo "$tname" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')
                TEAM_RESP=$(curl -fsS -X POST --max-time 5 \
                    -H "X-Admin-Token: ${ADMIN_TOKEN}" \
                    -H "Content-Type: application/json" \
                    -d "{\"name\":\"${tname}\",\"slug\":\"${slug}\"}" \
                    "${ADMIN}/teams" 2>/dev/null)
                TEAM_ID=$(echo "$TEAM_RESP" | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])" 2>/dev/null || echo "")
                if [[ -z "$TEAM_ID" ]]; then
                    err "Failed to create team. Response: $TEAM_RESP"
                    exit 1
                fi
                ok "Team created"
            fi

            echo ""
            ask "Key name (e.g. 'sandbox-key'):"
            read -rp "  > " kname
            KEY_RESP=$(curl -fsS -X POST --max-time 5 \
                -H "X-Admin-Token: ${ADMIN_TOKEN}" \
                -H "Content-Type: application/json" \
                -d "{\"name\":\"${kname}\"}" \
                "${ADMIN}/teams/${TEAM_ID}/keys" 2>/dev/null)
            RAW_KEY=$(echo "$KEY_RESP" | python3 -c "import sys,json; print(json.load(sys.stdin)['key'])" 2>/dev/null || echo "")
            if [[ -z "$RAW_KEY" ]]; then
                err "Failed to create key. Response: $KEY_RESP"
                exit 1
            fi
            ok "Key created: ${RAW_KEY:0:12}..."
            export ANTHROPIC_API_KEY="$RAW_KEY"
            echo ""
            echo -e "  ${Y}Save this key — it won't be shown again:${X}"
            echo -e "  ${B}${RAW_KEY}${X}"
            echo ""
            read -rp "  Press Enter to continue..."
            ;;
        3)
            ok "Portal: http://localhost:8005/portal/keys"
            echo ""
            ask "Paste the key once you have it (sk-...):"
            read -rsp "  > " key; echo ""
            export ANTHROPIC_API_KEY="$key"
            ;;
        *)
            err "Invalid choice"
            exit 1
            ;;
    esac
fi

# Validate the key looks right
if [[ ! "$ANTHROPIC_API_KEY" =~ ^sk- ]]; then
    warn "Key doesn't start with sk- — may not work"
fi
ok "Key: ${ANTHROPIC_API_KEY:0:12}..."
echo ""

# ── 4. Optional: pick a model ─────────────────────────────────────────────────
echo -e "${B}Model selection${X}"
MODELS_JSON=$(curl -fsS --max-time 5 \
    -H "Authorization: Bearer ${ANTHROPIC_API_KEY}" \
    "${GATEWAY}/v1/models" 2>/dev/null | \
    python3 -c "import sys,json; d=json.load(sys.stdin); [print(m['id']) for m in d.get('data',[])]" 2>/dev/null || true)

if [[ -n "$MODELS_JSON" ]]; then
    echo ""
    echo "  Available models:"
    echo "$MODELS_JSON" | head -10 | nl -ba -nln -w2 -v1 | sed 's/^/    /'
    MODEL_COUNT=$(echo "$MODELS_JSON" | wc -l)
    if [[ "$MODEL_COUNT" -gt 10 ]]; then
        echo "    ... and $((MODEL_COUNT - 10)) more"
    fi
    echo "    d) Use default (claude-sonnet-4-6)"
    echo ""
    ask "Pick a model number or press Enter for default:"
    read -rp "  > " mchoice
    if [[ -n "$mchoice" && "$mchoice" != "d" ]]; then
        CHOSEN_MODEL=$(echo "$MODELS_JSON" | sed -n "${mchoice}p")
        if [[ -n "$CHOSEN_MODEL" ]]; then
            export CLAUDE_MODEL="$CHOSEN_MODEL"
            ok "Model: ${CHOSEN_MODEL}"
        fi
    else
        ok "Model: default"
    fi
else
    warn "Could not fetch models (key may not be valid yet)"
fi
echo ""

# ── 5. Launch ─────────────────────────────────────────────────────────────────
echo -e "${B}Launching Claude Code...${X}"
echo -e "  Base URL : ${C}${ANTHROPIC_BASE_URL:-http://cache:8002/anthropic}${X}"
echo -e "  Key      : ${C}${ANTHROPIC_API_KEY:0:12}...${X}"
[[ -n "${CLAUDE_MODEL:-}" ]] && echo -e "  Model    : ${C}${CLAUDE_MODEL}${X}"
echo ""

MODEL_FLAG=""
[[ -n "${CLAUDE_MODEL:-}" ]] && MODEL_FLAG="--model ${CLAUDE_MODEL}"

# shellcheck disable=SC2086
exec claude $MODEL_FLAG "$@"
