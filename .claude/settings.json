{
  "permissions": {
    "allow": [
      "Bash(op item get *)",
      "Bash(op item list *)",
      "Bash(op whoami)",
      "Bash(op read *)",
      "Bash(op account list)",
      "Bash(mempalace status *)",
      "Bash(mempalace instructions *)",
      "mcp__claude_ai_Microsoft_365__read_resource",
      "mcp__claude_ai_Microsoft_365__sharepoint_search",
      "Bash(az network vnet subnet update:*)",
      "Bash(az network vnet subnet create:*)",
      "Bash(az network vnet update:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.py) ruff format \"$f\" && ruff check --fix \"$f\";; esac 2>/dev/null || true",
            "statusMessage": "ruff format"
          }
        ]
      }
    ]
  }
}
